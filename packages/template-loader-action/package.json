{
  "name": "@repo/template-loader-action",
  "description": "template-loader",
  "version": "0.1.0",
  "author": "kt",
  "type": "module",
  "private": true,
  "homepage": "https://github.com/ktkongtong/bili-action",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ktkongtong/bili-action.git"
  },
  "bugs": {
    "url": "https://github.com/ktkongtong/bili-action/issues"
  },
  "keywords": [
    "actions"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "bundle": "npm run package && mv dist/index.mjs ../../.github/actions/template-loader && rm -rf dist",
    "ci-test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest",
    "coverage": "npx make-coverage-badge --output-path ./badges/coverage.svg",
    "local-action": "npx @github/local-action . src/main.ts .env",
    "package": "npx rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "package:watch": "npm run package -- --watch",
    "test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest",
    "all": " npm run test && npm run coverage && npm run package"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "zod": "^3.24.2",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@github/local-action": "^3.1.0",
    "@jest/globals": "^29.7.0",
    "@rollup/plugin-commonjs": "^28.0.1",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.1.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.24",
    "jest": "^29.7.0",
    "make-coverage-badge": "^1.2.0",
    "rollup": "^4.35.0",
    "ts-jest": "^29.2.6",
    "ts-jest-resolver": "^2.0.1",
    "typescript": "^5.8.2"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  }
}
